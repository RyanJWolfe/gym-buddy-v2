<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing workout</h1>

  <%= render "edit_form", workout: @workout %>

  <%= link_to "Show this workout", user_workout_path(current_user, @workout), class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
  <%= link_to "Back to workouts", user_workouts_path(current_user), class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
</div>
