<div class="mx-auto md:w-2/3 w-full flex">
  <div class="mx-auto">
    <%= render @workout %>

    <%= link_to 'Edit this workout', edit_user_workout_path(current_user, @workout), class: "mt-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <div class="inline-block ml-2">
      <%= button_to 'Destroy this workout', user_workout_path(current_user, @workout), method: :delete, class: "mt-2 rounded-lg py-3 px-5 bg-gray-100 font-medium" %>
    </div>
    <%= link_to 'Back to workouts', user_workouts_path(current_user), class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
  </div>
</div>
