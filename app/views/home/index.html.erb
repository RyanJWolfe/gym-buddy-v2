<div class="space-y-4">
  <div>
    <h1 class="font-bold text-4xl">Welcome!</h1>
    <div class="flex space-x-2 items-center">
      <p class="text-muted">You are logged in as <%= current_user.email %></p>
      <%= button_to 'Logout', destroy_user_session_path, method: :delete, class: 'btn btn-tertiary' %>
    </div>
  </div>

  <div>
    <h2 class="font-bold text-2xl">Your Workouts</h2>
    <%= link_to 'New Workout', new_workout_path %>
    <%= render current_user.workouts %>
  </div>
</div>
